<!-- ================================================================
     Ye 3 lines <manifest ...> ke andar, <application> tag se PEHLE paste karo.
     (Apni existing AndroidManifest.xml me, poori file replace mat karo.)
     ================================================================ -->

<uses-permission android:name="android.permission.INTERNET" />

<!-- Android 9 aur usse purane par blob PDF direct Downloads folder me likhne ke liye.
     Android 10+ (API 29+) par iski zarurat nahi (MediaStore use hota hai). -->
<uses-permission
    android:name="android.permission.WRITE_EXTERNAL_STORAGE"
    android:maxSdkVersion="28" />

<!-- CAMERA sirf tab jab "report an issue" me camera se seedha photo lena ho.
     Sirf gallery upload chahiye to is line ki zarurat nahi. -->
<uses-permission android:name="android.permission.CAMERA" />


<!-- ================================================================
     NOTE: <application ...> tag ke andar ye attribute honi chahiye taaki
     https site load ho (default already true hai, bas confirm kar lena):

         android:usesCleartextTraffic="false"

     Aur agar site kuch http (non-https) content load karti hai to
     usko true karna pad sakta hai. Tumhari site https hai, so default theek hai.
     ================================================================ -->
